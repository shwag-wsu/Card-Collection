# App
NEXT_PUBLIC_APP_NAME=Card Collection MVP

# Storage
STORAGE_ROOT=/app/storage

# Database
POSTGRES_DB=cards
POSTGRES_USER=cards
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://cards:change_me@db:5432/cards

# Service wiring
ANALYZER_URL=http://analyzer:8000
ANALYZER_LOG_LEVEL=info

# AI pre-grade (optional but recommended)
OPENAI_API_KEY=
OPENAI_GRADING_MODEL=gpt-4.1-mini

# Market lookup (eBay Browse API)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US
